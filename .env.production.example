# Copy to .env on the production server (paridhanemporium.com)
# Replace placeholder secrets before going live.

NODE_ENV=production
PORT=4600
MONGO_URI=mongodb://127.0.0.1:27017/paridhan-db-prod
REDIS_URL=redis://127.0.0.1:6379

JWT_ACCESS_SECRET=change_me_long_random
JWT_REFRESH_SECRET=change_me_different_long_random
JWT_ACCESS_TTL=30m
JWT_REFRESH_TTL=7d

# Public URLs — NO localhost in production
STOREFRONT_URL=https://paridhanemporium.com
DASHBOARD_URL=https://admin.paridhanemporium.com
BACKEND_PUBLIC_URL=https://api.paridhanemporium.com

# Google OAuth (Google Console redirect URI must match exactly)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=https://api.paridhanemporium.com/api/v1/auth/google/callback

# Cashfree live
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=production
CASHFREE_WEBHOOK_SECRET=
