# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/paridhan-dev

# JWT signing (use long random values in production)
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_ACCESS_TTL=30m
JWT_REFRESH_TTL=7d

# Home hero carousel: max slides (1–12, default 5). GET /public/hero uses featured products first,
# then falls back to latest in-stock, then latest any. Seed marks the first HERO_SLIDE_LIMIT products featured.
HERO_SLIDE_LIMIT=5
# Optional image when a product has no photos (hero API only)
# HERO_PLACEHOLDER_IMAGE_URL=https://example.com/hero-fallback.jpg

# Server
PORT=4600
NODE_ENV=development
REDIS_URL=redis://127.0.0.1:6379
REDIS_AUTH_PREFIX=paridhan:auth
# Must match paridhan-api-gateway REDIS_CACHE_PREFIX for product cache busting on save
REDIS_CACHE_PREFIX=paridhan-gateway
TAX_RATE_PERCENT=5
SHIPPING_FREE_THRESHOLD=999
SHIPPING_BASE_FEE=80

# Seeder volume for dev load testing
SEED_PRODUCT_COUNT=300

# ── Client prep (npm run seed:clean) — keep categories; wipe products/orders/customers; new admin + seller ──

# ── Client bootstrap (npm run seed:client) — full wipe, admin + Paridhan Emporium seller only ──
# Set a strong SEED_PASSWORD before running on production.
SEED_PASSWORD=
SEED_ADMIN_EMAIL=admin@paridhanemporium.com
SEED_ADMIN_NAME=Platform Admin
SEED_SELLER_EMAIL=seller@paridhanemporium.com

# ── Dev-only full seed (npm run seed) — 300 sample products, test users ──
# SEED_PRODUCT_COUNT=300
# SEED_SELLER2_EMAIL=seller2@paridhan.com

# ImageKit (https://imagekit.io/docs) — client upload auth + server-side delete
IMAGEKIT_PUBLIC_KEY=public_/umtFMbimQzddKhB32UjVV5HSlA=
IMAGEKIT_PRIVATE_KEY=private_Jp/lygE8r9+SqRWiRI9yPi4sEZM=

# Cashfree Payment Gateway (https://www.cashfree.com/docs)
# Use sandbox credentials for development; set CASHFREE_ENV=production in live.
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
# Webhook secret from Cashfree Dashboard → Webhooks → your endpoint (not the API secret)
CASHFREE_WEBHOOK_SECRET=
CASHFREE_ENV=sandbox
# Storefront URL for payment return redirect (no trailing slash)
STOREFRONT_URL=http://localhost:3000
# Seller/admin dashboard URL (run dashboard on 3001: npm run dev -- -p 3001)
DASHBOARD_URL=http://localhost:3001

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI must match GOOGLE_OAUTH_CALLBACK_URL exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:4601/api/v1/auth/google/callback
# Optional separate secret for OAuth state JWT (defaults to JWT_ACCESS_SECRET)
# GOOGLE_OAUTH_STATE_SECRET=
# Public backend URL for Cashfree webhooks (use ngrok in local dev if testing webhooks)
BACKEND_PUBLIC_URL=http://localhost:4600

