# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/paridhan-dev

# JWT signing (use long random values in production)
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_ACCESS_TTL=30m
JWT_REFRESH_TTL=7d

# Home hero carousel: max slides from featured products (1–12, default 5)
HERO_SLIDE_LIMIT=5

# Server
PORT=5000
NODE_ENV=development
REDIS_URL=redis://127.0.0.1:6379
REDIS_AUTH_PREFIX=paridhan:auth
TAX_RATE_PERCENT=5
SHIPPING_FREE_THRESHOLD=999
SHIPPING_BASE_FEE=80

# Seeder volume for dev load testing
SEED_PRODUCT_COUNT=300

